# SHES Frontend – Environment Variables
# Copy this to .env and fill in values

# URL of the Django backend API (no trailing slash)
# In development, Vite's proxy handles /api → localhost:8000
VITE_API_URL=/api/v1

# For production, set this to the full backend URL:
# VITE_API_URL=https://your-backend.com/api/v1

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
