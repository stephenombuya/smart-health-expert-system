# ─── SHES Backend Environment Configuration ────────────────────────────────
# Copy this file to .env and fill in real values before running the server.
# NEVER commit .env to version control.

# ── Django Core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string-before-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://shes_user:shes_password@localhost:5432/shes_db

# ── JWT Token Lifetimes ───────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Encryption Key (for sensitive health data at rest) ───────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATELIMIT_DEFAULT=100/h
